{
  "name": "keep!t",
  "version": "1.0.1",
  "description": "Glassmorphic Notepad",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.keep!t.notepad",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "keep!t"
  },
  "keywords": [],
  "author": "New Potato",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  }
}
